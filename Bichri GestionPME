<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GestionPME — Tableau de bord</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --green: #1D9E75; --green-light: #E1F5EE; --green-dark: #0F6E56;
    --amber: #EF9F27; --amber-light: #FAEEDA;
    --red: #E24B4A; --red-light: #FCEBEB;
    --bg: #F4F2EC; --bg2: #FFFFFF; --bg3: #EEECE6;
    --text: #1A1917; --text2: #6B6963; --text3: #9A9890;
    --border: rgba(0,0,0,0.09); --border2: rgba(0,0,0,0.15);
    --radius: 10px; --radius-lg: 14px;
    --shadow: 0 1px 4px rgba(0,0,0,0.07), 0 0 0 0.5px rgba(0,0,0,0.07);
  }
  body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); font-size: 14px; line-height: 1.5; height: 100vh; overflow: hidden; }

  /* AUTH */
  #auth { display: flex; align-items: center; justify-content: center; height: 100vh; }
  .auth-wrap { width: 360px; }
  .auth-logo { font-size: 26px; font-weight: 600; text-align: center; margin-bottom: 2rem; letter-spacing: -0.5px; }
  .auth-logo span { color: var(--green); }
  .auth-card { background: var(--bg2); border-radius: var(--radius-lg); padding: 2rem; box-shadow: var(--shadow); }
  .auth-sub { font-size: 13px; color: var(--text2); text-align: center; margin-bottom: 1.5rem; }
  .field { margin-bottom: 1rem; }
  .field label { display: block; font-size: 12px; font-weight: 500; color: var(--text2); margin-bottom: 5px; }
  .field input { width: 100%; padding: 10px 12px; border: 0.5px solid var(--border2); border-radius: var(--radius); font-family: inherit; font-size: 14px; color: var(--text); background: var(--bg); outline: none; transition: border-color .15s; }
  .field input:focus { border-color: var(--green); }
  .btn-auth { width: 100%; padding: 11px; background: var(--green); color: #fff; border: none; border-radius: var(--radius); font-family: inherit; font-size: 14px; font-weight: 500; cursor: pointer; transition: background .15s; }
  .btn-auth:hover { background: var(--green-dark); }
  .auth-hint { font-size: 11px; color: var(--text3); text-align: center; margin-top: 1rem; }

  /* LAYOUT */
  #app { display: none; height: 100vh; }
  .layout { display: flex; height: 100%; }

  /* SIDEBAR */
  .sidebar { width: 210px; background: var(--bg2); border-right: 0.5px solid var(--border); display: flex; flex-direction: column; flex-shrink: 0; padding: 1rem 0; }
  .s-logo { padding: 0 1.125rem 1rem; font-size: 17px; font-weight: 600; border-bottom: 0.5px solid var(--border); margin-bottom: .75rem; }
  .s-logo span { color: var(--green); }
  .s-user { padding: .5rem 1.125rem .875rem; border-bottom: 0.5px solid var(--border); margin-bottom: .5rem; }
  .s-user-name { font-size: 13px; font-weight: 500; }
  .s-user-role { font-size: 11px; color: var(--text3); margin-top: 1px; }
  .s-nav { flex: 1; display: flex; flex-direction: column; gap: 2px; padding: 0 .5rem; }
  .nav-item { display: flex; align-items: center; gap: 9px; padding: 8px 10px; border-radius: 8px; cursor: pointer; font-size: 13px; color: var(--text2); transition: all .12s; }
  .nav-item:hover { background: var(--bg3); color: var(--text); }
  .nav-item.active { background: var(--green-light); color: var(--green-dark); font-weight: 500; }
  .nav-item i { font-size: 17px; }
  .s-bottom { padding: 1rem .5rem 0; border-top: 0.5px solid var(--border); }
  .s-logout { display: flex; align-items: center; gap: 9px; padding: 8px 10px; border-radius: 8px; cursor: pointer; font-size: 13px; color: var(--text3); transition: all .12s; }
  .s-logout:hover { color: var(--red); background: var(--red-light); }

  /* MAIN */
  .main { flex: 1; overflow-y: auto; background: var(--bg); }
  .page { display: none; padding: 1.5rem; }
  .page.active { display: block; }
  .topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
  .topbar h1 { font-size: 18px; font-weight: 600; letter-spacing: -0.3px; }
  .topbar-right { display: flex; gap: 8px; }

  /* BUTTONS */
  .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: var(--radius); border: 0.5px solid var(--border2); background: var(--bg2); color: var(--text); font-family: inherit; font-size: 13px; font-weight: 500; cursor: pointer; transition: all .12s; }
  .btn:hover { background: var(--bg3); }
  .btn.primary { background: var(--green); color: #fff; border-color: var(--green); }
  .btn.primary:hover { background: var(--green-dark); }

  /* METRICS */
  .metrics { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; margin-bottom: 1.5rem; }
  .metric { background: var(--bg2); border-radius: var(--radius-lg); padding: 1.125rem; border: 0.5px solid var(--border); }
  .metric-label { font-size: 11px; color: var(--text2); font-weight: 500; text-transform: uppercase; letter-spacing: .04em; margin-bottom: 6px; }
  .metric-value { font-size: 22px; font-weight: 600; letter-spacing: -0.5px; }
  .metric-trend { font-size: 11px; margin-top: 4px; }
  .trend-up { color: var(--green); }
  .trend-down { color: var(--red); }
  .trend-warn { color: var(--amber); }

  /* SECTION */
  .section { background: var(--bg2); border-radius: var(--radius-lg); border: 0.5px solid var(--border); padding: 1.25rem; margin-bottom: 1.25rem; }
  .section-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; }
  .section-head h2 { font-size: 14px; font-weight: 600; }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem; }

  /* TABLE */
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th { text-align: left; font-size: 11px; color: var(--text2); padding: 0 10px 10px; font-weight: 500; text-transform: uppercase; letter-spacing: .04em; }
  td { padding: 10px; border-top: 0.5px solid var(--border); color: var(--text); vertical-align: middle; }
  tr:hover td { background: var(--bg); }
  .status { display: inline-block; font-size: 11px; font-weight: 500; padding: 3px 9px; border-radius: 20px; }
  .s-paid { background: var(--green-light); color: var(--green-dark); }
  .s-pending { background: var(--amber-light); color: #854F0B; }
  .s-late { background: var(--red-light); color: #A32D2D; }

  /* CHART */
  .chart { display: flex; align-items: flex-end; gap: 8px; height: 110px; padding-top: 10px; }
  .bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; height: 100%; justify-content: flex-end; }
  .bar { width: 100%; border-radius: 4px 4px 0 0; }
  .bar-lbl { font-size: 10px; color: var(--text3); }

  /* STOCK BAR */
  .stock-bar { height: 6px; background: var(--bg3); border-radius: 4px; margin-top: 5px; }
  .stock-fill { height: 100%; border-radius: 4px; }

  /* FORM */
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 12px; }
  .fg { display: flex; flex-direction: column; gap: 5px; margin-bottom: 12px; }
  .fg label { font-size: 12px; font-weight: 500; color: var(--text2); }
  .fg input, .fg select, .fg textarea { padding: 9px 11px; border: 0.5px solid var(--border2); border-radius: var(--radius); font-family: inherit; font-size: 13px; color: var(--text); background: var(--bg); outline: none; transition: border-color .15s; }
  .fg input:focus, .fg select:focus { border-color: var(--green); }
  .fg textarea { resize: vertical; min-height: 70px; }

  /* INVOICE */
  .invoice-preview { background: #fff; border: 0.5px solid var(--border); border-radius: var(--radius); padding: 1.5rem; font-size: 12px; }
  .inv-header { display: flex; justify-content: space-between; margin-bottom: 1.25rem; padding-bottom: 1rem; border-bottom: 2px solid var(--green); }
  .inv-title { font-size: 24px; font-weight: 600; color: var(--green); }
  .inv-table { width: 100%; border-collapse: collapse; margin: 1rem 0; }
  .inv-table th { background: var(--green-light); padding: 8px 10px; text-align: left; font-size: 11px; color: var(--green-dark); font-weight: 500; }
  .inv-table td { padding: 8px 10px; border-bottom: 0.5px solid var(--border); }
  .inv-total { text-align: right; font-weight: 600; font-size: 14px; color: var(--green-dark); margin-top: 8px; }

  /* PAYMENT */
  .pay-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 1.25rem; }
  .pay-option { border: 1.5px solid var(--border); border-radius: var(--radius-lg); padding: 1rem; cursor: pointer; text-align: center; transition: all .15s; }
  .pay-option:hover { border-color: var(--green); }
  .pay-option.selected { border-color: var(--green); background: var(--green-light); }
  .pay-icon { font-size: 30px; margin-bottom: 6px; }
  .pay-name { font-size: 13px; font-weight: 600; }
  .pay-desc { font-size: 11px; color: var(--text2); margin-top: 2px; }

  /* MODAL */
  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.35); z-index: 200; align-items: center; justify-content: center; }
  .modal-overlay.open { display: flex; }
  .modal { background: var(--bg2); border-radius: var(--radius-lg); padding: 1.5rem; width: 380px; max-width: 95vw; box-shadow: 0 8px 32px rgba(0,0,0,0.15); }
  .modal h2 { font-size: 16px; font-weight: 600; margin-bottom: 1.25rem; }
  .modal-btns { display: flex; gap: 8px; justify-content: flex-end; margin-top: 1.25rem; }

  /* TOAST */
  .toast { position: fixed; bottom: 24px; right: 24px; background: var(--text); color: #fff; padding: 12px 18px; border-radius: var(--radius); font-size: 13px; font-weight: 500; z-index: 999; opacity: 0; transform: translateY(8px); transition: all .25s; pointer-events: none; }
  .toast.show { opacity: 1; transform: translateY(0); }

  /* LOADING */
  .loading { text-align: center; padding: 2rem; color: var(--text3); font-size: 13px; }
</style>
</head>
<body>

<!-- AUTH -->
<div id="auth">
  <div class="auth-wrap">
    <div class="auth-logo">Gestion<span>PME</span></div>
    <div class="auth-card">
      <p class="auth-sub">Connectez-vous à votre espace</p>
      <div class="field"><label>Email</label><input type="email" id="auth-email" placeholder="votre@email.sn"></div>
      <div class="field"><label>Mot de passe</label><input type="password" id="auth-pass" placeholder="Mot de passe"></div>
      <button class="btn-auth" onclick="login()">Se connecter</button>
      <p class="auth-hint">Pas encore de compte ? <span style="color:var(--green);cursor:pointer" onclick="register()">Créer un compte</span></p>
    </div>
  </div>
</div>

<!-- APP -->
<div id="app">
  <div class="layout">
    <div class="sidebar">
      <div class="s-logo">Gestion<span>PME</span></div>
      <div class="s-user">
        <div class="s-user-name" id="u-name">Chargement...</div>
        <div class="s-user-role">Gérant principal</div>
      </div>
      <div class="s-nav">
        <div class="nav-item active" onclick="nav('dashboard',this)"><i class="ti ti-layout-dashboard"></i> Tableau de bord</div>
        <div class="nav-item" onclick="nav('factures',this)"><i class="ti ti-file-invoice"></i> Factures</div>
        <div class="nav-item" onclick="nav('paiements',this)"><i class="ti ti-device-mobile"></i> Paiements</div>
        <div class="nav-item" onclick="nav('stocks',this)"><i class="ti ti-package"></i> Stocks</div>
        <div class="nav-item" onclick="nav('clients',this)"><i class="ti ti-users"></i> Clients</div>
      </div>
      <div class="s-bottom">
        <div class="s-logout" onclick="logout()"><i class="ti ti-logout"></i> Déconnexion</div>
      </div>
    </div>

    <div class="main">

      <!-- DASHBOARD -->
      <div id="dashboard" class="page active">
        <div class="topbar"><h1>Tableau de bord</h1><span style="font-size:12px;color:var(--text2)" id="dash-date"></span></div>
        <div class="metrics">
          <div class="metric"><div class="metric-label">Chiffre d'affaires</div><div class="metric-value" id="stat-ca">—</div><div class="metric-trend trend-up">Total factures payées</div></div>
          <div class="metric"><div class="metric-label">Factures</div><div class="metric-value" id="stat-factures">—</div><div class="metric-trend trend-warn">Total émises</div></div>
          <div class="metric"><div class="metric-label">Clients</div><div class="metric-value" id="stat-clients">—</div><div class="metric-trend trend-up">Enregistrés</div></div>
          <div class="metric"><div class="metric-label">Produits stock</div><div class="metric-value" id="stat-stocks">—</div><div class="metric-trend trend-down">À surveiller</div></div>
        </div>
        <div class="two-col">
          <div class="section">
            <div class="section-head"><h2>Revenus mensuels</h2></div>
            <div class="chart">
              <div class="bar-wrap"><div class="bar" style="height:50%;background:#9FE1CB"></div><div class="bar-lbl">Jan</div></div>
              <div class="bar-wrap"><div class="bar" style="height:60%;background:#9FE1CB"></div><div class="bar-lbl">Fév</div></div>
              <div class="bar-wrap"><div class="bar" style="height:45%;background:#9FE1CB"></div><div class="bar-lbl">Mar</div></div>
              <div class="bar-wrap"><div class="bar" style="height:68%;background:#9FE1CB"></div><div class="bar-lbl">Avr</div></div>
              <div class="bar-wrap"><div class="bar" style="height:85%;background:var(--green)"></div><div class="bar-lbl">Mai</div></div>
            </div>
          </div>
          <div class="section">
            <div class="section-head"><h2>Dernières factures</h2></div>
            <div id="dash-factures"><div class="loading">Chargement...</div></div>
          </div>
        </div>
      </div>

      <!-- FACTURES -->
      <div id="factures" class="page">
        <div class="topbar"><h1>Factures</h1><button class="btn primary" onclick="nav('nouvelle-facture',null)"><i class="ti ti-plus"></i> Nouvelle facture</button></div>
        <div class="section">
          <div id="factures-list"><div class="loading">Chargement...</div></div>
        </div>
      </div>

      <!-- NOUVELLE FACTURE -->
      <div id="nouvelle-facture" class="page">
        <div class="topbar"><h1>Nouvelle facture</h1>
          <div class="topbar-right">
            <button class="btn" onclick="nav('factures',null)">Annuler</button>
            <button class="btn primary" onclick="saveFacture()"><i class="ti ti-check"></i> Enregistrer</button>
          </div>
        </div>
        <div class="two-col">
          <div>
            <div class="section">
              <div class="section-head"><h2>Informations</h2></div>
              <div class="form-row">
                <div class="fg"><label>Client</label><input type="text" id="f-client" placeholder="Nom du client"></div>
                <div class="fg"><label>Date</label><input type="date" id="f-date"></div>
              </div>
              <div class="fg"><label>Description</label><textarea id="f-desc" placeholder="Détail de la prestation..."></textarea></div>
              <div class="form-row">
                <div class="fg"><label>Quantité</label><input type="number" id="f-qty" value="1" oninput="calcInvoice()"></div>
                <div class="fg"><label>Prix unitaire (FCFA)</label><input type="number" id="f-price" value="0" oninput="calcInvoice()"></div>
              </div>
              <div style="display:flex;justify-content:space-between;align-items:center;padding-top:12px;border-top:0.5px solid var(--border)">
                <span style="font-size:13px;color:var(--text2)">Total</span>
                <span id="f-total" style="font-size:18px;font-weight:600;color:var(--green)">0 FCFA</span>
              </div>
            </div>
          </div>
          <div class="section">
            <div class="section-head"><h2>Aperçu</h2></div>
            <div class="invoice-preview">
              <div class="inv-header">
                <div><div class="inv-title">FACTURE</div><div style="font-size:11px;color:#888;margin-top:3px" id="prev-num">Nouvelle · Aujourd'hui</div></div>
                <div style="text-align:right"><div style="font-weight:600;font-size:13px">Mon Entreprise</div><div style="font-size:11px;color:#888">Dakar, Sénégal</div></div>
              </div>
              <div style="font-size:11px;color:#888;margin-bottom:12px">Facturé à : <span id="prev-client" style="color:#222;font-weight:500">—</span></div>
              <table class="inv-table">
                <thead><tr><th>Description</th><th>Qté</th><th>Prix unit.</th><th>Total</th></tr></thead>
                <tbody><tr><td id="prev-desc">—</td><td id="prev-qty">1</td><td id="prev-pu">0 F</td><td id="prev-total">0 F</td></tr></tbody>
              </table>
              <div class="inv-total">Total : <span id="prev-grand">0 FCFA</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- PAIEMENTS -->
      <div id="paiements" class="page">
        <div class="topbar"><h1>Paiements Mobile Money</h1></div>
        <div class="two-col">
          <div class="section">
            <div class="section-head"><h2>Envoyer une demande</h2></div>
            <div class="pay-grid">
              <div class="pay-option selected" id="opt-wave" onclick="selectPay('wave')">
                <div class="pay-icon">🌊</div><div class="pay-name">Wave</div><div class="pay-desc">Instantané · 1% frais</div>
              </div>
              <div class="pay-option" id="opt-om" onclick="selectPay('om')">
                <div class="pay-icon">🟠</div><div class="pay-name">Orange Money</div><div class="pay-desc">Réseau étendu · 1.5%</div>
              </div>
            </div>
            <div class="fg"><label>Numéro du client</label><input type="tel" id="pay-phone" placeholder="+221 77 000 00 00"></div>
            <div class="fg"><label>Montant (FCFA)</label><input type="number" id="pay-amount" placeholder="0"></div>
            <button class="btn primary" style="width:100%" onclick="sendPayment()"><i class="ti ti-send"></i> Envoyer la demande</button>
          </div>
          <div class="section">
            <div class="section-head"><h2>Historique</h2></div>
            <table>
              <thead><tr><th>Client</th><th>Méthode</th><th>Montant</th></tr></thead>
              <tbody id="pay-history">
                <tr><td>SARL Diallo</td><td>🌊 Wave</td><td><strong>320 000 F</strong></td></tr>
                <tr><td>Ndiaye SARL</td><td>🟠 Orange Money</td><td><strong>470 000 F</strong></td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- STOCKS -->
      <div id="stocks" class="page">
        <div class="topbar"><h1>Stocks</h1><button class="btn primary" onclick="openModal('modal-stock')"><i class="ti ti-plus"></i> Ajouter produit</button></div>
        <div class="section">
          <div id="stocks-list"><div class="loading">Chargement...</div></div>
        </div>
      </div>

      <!-- CLIENTS -->
      <div id="clients" class="page">
        <div class="topbar"><h1>Clients</h1><button class="btn primary" onclick="openModal('modal-client')"><i class="ti ti-plus"></i> Ajouter client</button></div>
        <div class="section">
          <div id="clients-list"><div class="loading">Chargement...</div></div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- MODAL STOCK -->
<div class="modal-overlay" id="modal-stock">
  <div class="modal">
    <h2>Ajouter un produit</h2>
    <div class="fg"><label>Nom du produit</label><input id="s-name" type="text" placeholder="ex: Riz Basmati 25kg"></div>
    <div class="form-row">
      <div class="fg"><label>Quantité</label><input id="s-qty" type="number" placeholder="0" min="0"></div>
      <div class="fg"><label>Seuil minimum</label><input id="s-min" type="number" placeholder="0" min="0"></div>
    </div>
    <div class="modal-btns">
      <button class="btn" onclick="closeModal('modal-stock')">Annuler</button>
      <button class="btn primary" onclick="addStock()"><i class="ti ti-check"></i> Ajouter</button>
    </div>
  </div>
</div>

<!-- MODAL CLIENT -->
<div class="modal-overlay" id="modal-client">
  <div class="modal">
    <h2>Ajouter un client</h2>
    <div class="fg"><label>Nom / Entreprise</label><input id="c-name" type="text" placeholder="ex: SARL Diallo"></div>
    <div class="fg"><label>Téléphone</label><input id="c-tel" type="tel" placeholder="+221 77 000 00 00"></div>
    <div class="fg"><label>Ville</label><input id="c-ville" type="text" placeholder="ex: Dakar"></div>
    <div class="modal-btns">
      <button class="btn" onclick="closeModal('modal-client')">Annuler</button>
      <button class="btn primary" onclick="addClient()"><i class="ti ti-check"></i> Ajouter</button>
    </div>
  </div>
</div>

<!-- MODAL FACTURE PDF -->
<div class="modal-overlay" id="modal-invoice">
  <div class="modal" style="width:460px;max-width:95vw">
    <h2>Aperçu facture</h2>
    <div id="modal-invoice-content" style="margin:1rem 0"></div>
    <div class="modal-btns">
      <button class="btn" onclick="closeModal('modal-invoice')">Fermer</button>
      <button class="btn primary" onclick="toast('PDF téléchargé !')"><i class="ti ti-download"></i> Télécharger PDF</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
  // ===== SUPABASE CONFIG =====
  const SUPABASE_URL = 'https://ovsmvyfslglvxpccaqgx.supabase.co';
  const SUPABASE_KEY = 'sb_publishable_6p_YxOp2xXLetOSQkU4FPQ__yZWTw0m';
  const { createClient } = supabase;
  const sb = createClient(SUPABASE_URL, SUPABASE_KEY);

  // ===== AUTH =====
  async function login() {
    const email = document.getElementById('auth-email').value;
    const pass  = document.getElementById('auth-pass').value;
    if (!email || !pass) { toast('Remplis email et mot de passe'); return; }
    const { data, error } = await sb.auth.signInWithPassword({ email, password: pass });
    if (error) { toast('Erreur : ' + error.message); return; }
    showApp(data.user);
  }

  async function register() {
    const email = document.getElementById('auth-email').value;
    const pass  = document.getElementById('auth-pass').value;
    if (!email || !pass) { toast('Remplis email et mot de passe'); return; }
    const { data, error } = await sb.auth.signUp({ email, password: pass });
    if (error) { toast('Erreur : ' + error.message); return; }
    toast('Compte créé ! Vérifie ton email.');
  }

  async function logout() {
    await sb.auth.signOut();
    document.getElementById('auth').style.display = 'flex';
    document.getElementById('app').style.display = 'none';
  }

  function showApp(user) {
    document.getElementById('auth').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    document.getElementById('u-name').textContent = user.email.split('@')[0];
    document.getElementById('dash-date').textContent = new Date().toLocaleDateString('fr-FR', {day:'numeric',month:'long',year:'numeric'});
    document.getElementById('f-date').value = new Date().toISOString().split('T')[0];
    loadDashboard();
    loadFactures();
    loadClients();
    loadStocks();
  }

  // Auto-login si session active
  sb.auth.getSession().then(({ data }) => {
    if (data.session) showApp(data.session.user);
  });

  // ===== NAVIGATION =====
  function nav(id, el) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    if (el) el.classList.add('active');
    else {
      const map = {'dashboard':0,'factures':1,'paiements':2,'stocks':3,'clients':4,'nouvelle-facture':1};
      const items = document.querySelectorAll('.nav-item');
      if (map[id] !== undefined) items[map[id]].classList.add('active');
    }
  }

  // ===== DASHBOARD =====
  async function loadDashboard() {
    const { data: factures } = await sb.from('factures').select('*');
    const { data: clients }  = await sb.from('clients').select('*');
    const { data: stocks }   = await sb.from('stocks').select('*');

    const ca = (factures || []).filter(f => f.statut === 'Payée').reduce((s, f) => s + (f.montant || 0), 0);
    document.getElementById('stat-ca').textContent = ca.toLocaleString('fr-FR') + ' F';
    document.getElementById('stat-factures').textContent = (factures || []).length;
    document.getElementById('stat-clients').textContent = (clients || []).length;
    document.getElementById('stat-stocks').textContent = (stocks || []).filter(s => s.quantite <= s.seuil_min).length;

    // Dernières factures
    const last = (factures || []).slice(-4).reverse();
    document.getElementById('dash-factures').innerHTML = last.length ? `
      <table><thead><tr><th>Client</th><th>Montant</th><th>Statut</th></tr></thead><tbody>
      ${last.map(f => `<tr><td>${f.client}</td><td>${(f.montant||0).toLocaleString('fr-FR')} F</td><td><span class="status ${statusClass(f.statut)}">${f.statut}</span></td></tr>`).join('')}
      </tbody></table>` : '<div class="loading">Aucune facture</div>';
  }

  // ===== FACTURES =====
  async function loadFactures() {
    const { data } = await sb.from('factures').select('*').order('id', { ascending: false });
    document.getElementById('factures-list').innerHTML = (data && data.length) ? `
      <table><thead><tr><th>Client</th><th>Date</th><th>Montant</th><th>Statut</th><th>Action</th></tr></thead><tbody>
      ${data.map(f => `<tr>
        <td><strong>${f.client}</strong></td>
        <td>${f.date || '—'}</td>
        <td><strong>${(f.montant||0).toLocaleString('fr-FR')} F</strong></td>
        <td><span class="status ${statusClass(f.statut)}">${f.statut}</span></td>
        <td><button class="btn" onclick="showInvoice('${f.client}','${(f.montant||0).toLocaleString('fr-FR')}','${f.date||''}')">PDF</button></td>
      </tr>`).join('')}
      </tbody></table>` : '<div class="loading">Aucune facture enregistrée</div>';
  }

  function statusClass(s) {
    if (s === 'Payée') return 's-paid';
    if (s === 'En attente') return 's-pending';
    return 's-late';
  }

  function calcInvoice() {
    const qty = parseFloat(document.getElementById('f-qty').value) || 0;
    const pu  = parseFloat(document.getElementById('f-price').value) || 0;
    const total = qty * pu;
    const fmt = total.toLocaleString('fr-FR');
    document.getElementById('f-total').textContent = fmt + ' FCFA';
    document.getElementById('prev-client').textContent = document.getElementById('f-client').value || '—';
    document.getElementById('prev-desc').textContent = document.getElementById('f-desc').value || '—';
    document.getElementById('prev-qty').textContent = qty;
    document.getElementById('prev-pu').textContent = pu.toLocaleString('fr-FR') + ' F';
    document.getElementById('prev-total').textContent = fmt + ' F';
    document.getElementById('prev-grand').textContent = fmt + ' FCFA';
  }

  async function saveFacture() {
    const client  = document.getElementById('f-client').value.trim();
    const date    = document.getElementById('f-date').value;
    const desc    = document.getElementById('f-desc').value.trim();
    const qty     = parseFloat(document.getElementById('f-qty').value) || 0;
    const price   = parseFloat(document.getElementById('f-price').value) || 0;
    const montant = qty * price;
    if (!client) { toast('Indique le nom du client'); return; }
    const { error } = await sb.from('factures').insert([{ client, date, description: desc, montant, statut: 'En attente' }]);
    if (error) { toast('Erreur : ' + error.message); return; }
    toast('Facture enregistrée !');
    loadFactures();
    loadDashboard();
    nav('factures', null);
  }

  function showInvoice(client, amount, date) {
    document.getElementById('modal-invoice-content').innerHTML = `
      <div class="invoice-preview">
        <div class="inv-header">
          <div><div class="inv-title">FACTURE</div><div style="font-size:11px;color:#888;margin-top:3px">${date}</div></div>
          <div style="text-align:right"><div style="font-weight:600;font-size:13px">Mon Entreprise</div><div style="font-size:11px;color:#888">Dakar, Sénégal</div></div>
        </div>
        <div style="font-size:11px;color:#888;margin-bottom:12px">Facturé à : <span style="color:#222;font-weight:500">${client}</span></div>
        <table class="inv-table"><thead><tr><th>Description</th><th>Total</th></tr></thead>
        <tbody><tr><td>Prestation</td><td>${amount} FCFA</td></tr></tbody></table>
        <div class="inv-total">Total : ${amount} FCFA</div>
      </div>`;
    openModal('modal-invoice');
  }

  // ===== CLIENTS =====
  async function loadClients() {
    const { data } = await sb.from('clients').select('*').order('id', { ascending: false });
    document.getElementById('clients-list').innerHTML = (data && data.length) ? `
      <table><thead><tr><th>Nom</th><th>Téléphone</th><th>Ville</th><th>CA total</th></tr></thead><tbody>
      ${data.map(c => `<tr>
        <td><strong>${c.nom}</strong></td>
        <td>${c.telephone || '—'}</td>
        <td>${c.ville || '—'}</td>
        <td><strong>${(c.ca_total||0).toLocaleString('fr-FR')} F</strong></td>
      </tr>`).join('')}
      </tbody></table>` : '<div class="loading">Aucun client enregistré</div>';
  }

  async function addClient() {
    const nom      = document.getElementById('c-name').value.trim();
    const telephone = document.getElementById('c-tel').value.trim();
    const ville    = document.getElementById('c-ville').value.trim();
    if (!nom) { toast('Indique le nom du client'); return; }
    const { error } = await sb.from('clients').insert([{ nom, telephone, ville, ca_total: 0 }]);
    if (error) { toast('Erreur : ' + error.message); return; }
    document.getElementById('c-name').value = '';
    document.getElementById('c-tel').value = '';
    document.getElementById('c-ville').value = '';
    closeModal('modal-client');
    toast('Client "' + nom + '" ajouté !');
    loadClients();
    loadDashboard();
  }

  // ===== STOCKS =====
  async function loadStocks() {
    const { data } = await sb.from('stocks').select('*').order('id', { ascending: false });
    document.getElementById('stocks-list').innerHTML = (data && data.length) ? `
      <table><thead><tr><th>Produit</th><th>Quantité</th><th>Seuil min.</th><th>Niveau</th><th>Statut</th></tr></thead><tbody>
      ${data.map(s => {
        const pct = s.seuil_min > 0 ? Math.min(100, Math.round((s.quantite / s.seuil_min) * 50)) : 100;
        const color = pct > 60 ? 'var(--green)' : pct > 30 ? 'var(--amber)' : 'var(--red)';
        const status = pct > 60 ? '<span class="status s-paid">OK</span>' : pct > 30 ? '<span class="status s-pending">Faible</span>' : '<span class="status s-late">Critique</span>';
        return `<tr>
          <td>${s.nom_produit}</td>
          <td>${s.quantite}</td>
          <td>${s.seuil_min}</td>
          <td><div class="stock-bar"><div class="stock-fill" style="width:${pct}%;background:${color}"></div></div></td>
          <td>${status}</td>
        </tr>`;
      }).join('')}
      </tbody></table>` : '<div class="loading">Aucun produit en stock</div>';
  }

  async function addStock() {
    const nom_produit = document.getElementById('s-name').value.trim();
    const quantite    = parseInt(document.getElementById('s-qty').value) || 0;
    const seuil_min   = parseInt(document.getElementById('s-min').value) || 0;
    if (!nom_produit) { toast('Indique le nom du produit'); return; }
    const { error } = await sb.from('stocks').insert([{ nom_produit, quantite, seuil_min }]);
    if (error) { toast('Erreur : ' + error.message); return; }
    document.getElementById('s-name').value = '';
    document.getElementById('s-qty').value = '';
    document.getElementById('s-min').value = '';
    closeModal('modal-stock');
    toast('Produit "' + nom_produit + '" ajouté !');
    loadStocks();
    loadDashboard();
  }

  // ===== PAIEMENTS =====
  var selPay = 'wave';
  function selectPay(m) {
    selPay = m;
    document.getElementById('opt-wave').classList.toggle('selected', m === 'wave');
    document.getElementById('opt-om').classList.toggle('selected', m === 'om');
  }
  function sendPayment() {
    const phone  = document.getElementById('pay-phone').value;
    const amount = document.getElementById('pay-amount').value;
    if (!phone || !amount) { toast('Remplis le numéro et le montant'); return; }
    const method = selPay === 'wave' ? '🌊 Wave' : '🟠 Orange Money';
    const row = `<tr><td>Nouveau client</td><td>${method}</td><td><strong>${parseInt(amount).toLocaleString('fr-FR')} F</strong></td></tr>`;
    document.getElementById('pay-history').insertAdjacentHTML('afterbegin', row);
    document.getElementById('pay-phone').value = '';
    document.getElementById('pay-amount').value = '';
    toast('Demande envoyée via ' + method + ' !');
  }

  // ===== MODALS =====
  function openModal(id)  { document.getElementById(id).classList.add('open'); }
  function closeModal(id) { document.getElementById(id).classList.remove('open'); }
  document.querySelectorAll('.modal-overlay').forEach(o => {
    o.addEventListener('click', e => { if (e.target === o) o.classList.remove('open'); });
  });

  // ===== TOAST =====
  function toast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg; t.classList.add('show');
    clearTimeout(t._t);
    t._t = setTimeout(() => t.classList.remove('show'), 2800);
  }

  // Live preview
  document.addEventListener('input', e => {
    if (['f-client','f-desc','f-qty','f-price'].includes(e.target.id)) calcInvoice();
  });
</script>
</body>
</html>
